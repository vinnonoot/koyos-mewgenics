<!DOCTYPE html>
<html>
<head>
  <title>mewgenics koyos</title>
  <style>
    body {
      text-align: center;
      font-family: sans-serif;
      margin-top: 100px;
      background: #111;
      color: white;
    }

    #popup {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.85);
      justify-content: center;
      align-items: center;
      flex-direction: column;
    }

    #popup img {
      max-width: 70%;
      border: 4px solid white;
      box-shadow: 0 0 20px #fff;
      margin-bottom: 20px;
    }

    button {
      padding: 15px 35px;
      font-size: 20px;
      cursor: pointer;
      border: none;
      background: #4CAF50;
      color: white;
      border-radius: 8px;
      transition: 0.2s;
    }

    button:hover {
      background: #45a049;
    }

    a.download-link {
      padding: 12px 25px;
      background: #2196F3;
      color: white;
      border-radius: 6px;
      text-decoration: none;
      font-size: 18px;
      margin-top: 10px;
    }

    a.download-link:hover {
      background: #0b7dda;
    }
  </style>
</head>
<body>

  <h1>Click to download the game</h1>
  <button onclick="showPopup()">Download Now</button>

  <div id="popup" onclick="closePopup(event)">
    <img src="https://rule34storage.b-cdn.net/posts/1026/1026294/1026294.picsmall.jpg" alt="Game Preview">
    <a class="download-link" href="your-game-file.zip" download>Click here to download</a>
  </div>

  <script>
    function showPopup() {
      document.getElementById("popup").style.display = "flex";
    }

    function closePopup(event) {
      if (event.target.id === "popup") {
        document.getElementById("popup").style.display = "none";
      }
    }
  </script>

</body>
</html>
